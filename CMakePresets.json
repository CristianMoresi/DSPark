{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Release)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DSPARK_BUILD_CONFORMANCE": "ON"
      }
    },
    {
      "name": "msvc",
      "displayName": "Windows MSVC x64 (default Visual Studio)",
      "inherits": "default",
      "architecture": "x64",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "ninja",
      "displayName": "Ninja (any platform)",
      "inherits": "default",
      "generator": "Ninja"
    },
    {
      "name": "sanitize",
      "displayName": "ASan + UBSan (GCC/Clang)",
      "inherits": "ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-sanitize-recover=all"
      },
      "condition": { "type": "notEquals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default" },
    { "name": "msvc", "configurePreset": "msvc", "configuration": "Release" },
    { "name": "ninja", "configurePreset": "ninja" }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "msvc",
      "configurePreset": "msvc",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
